# HR Tool — Environment Variables
# Copy this file to .env.local (frontend) and fill in the values.
# NEVER commit the actual .env / .env.local files.

# ──────────────────────────────────────
# Frontend (Vite) — goes in .env.local
# ──────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ──────────────────────────────────────
# Edge Functions — goes in supabase/functions/.env (local)
# or Supabase dashboard → Edge Functions → Secrets (prod)
# ──────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
RESEND_API_KEY=<resend-key>
APP_ENV=development
