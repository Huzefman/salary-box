# SalaryBox — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file.

# ──────────────────────────────────────
# App
# ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ──────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/salarybox_dev

# ──────────────────────────────────────
# Authentication / JWT
# ──────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────
# File Storage (AWS S3 / Cloudflare R2)
# ──────────────────────────────────────
STORAGE_PROVIDER=s3               # s3 | r2 | local
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=salarybox-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ──────────────────────────────────────
# Email (SMTP)
# ──────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SalaryBox HR <noreply@example.com>"

# ──────────────────────────────────────
# Firebase (Push / In-app Notifications)
# ──────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=   # path to service account JSON

# ──────────────────────────────────────
# SSO (optional)
# ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ──────────────────────────────────────
# Frontend (Vite / Next.js public vars)
# ──────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1
